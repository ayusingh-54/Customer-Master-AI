# ─────────────────────────────────────────────────────────────────────────────
# Customer Master AI — Environment Variables
# Copy to .env for local development.  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment ────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
PORT=10000                       # HTTP port (Render sets this automatically)
WORKERS=1                        # Gunicorn workers (keep 1 for SQLite)

# ── Auth ──────────────────────────────────────────────────────────────────────
# In development: leave as "dev-secret-key" → auth is OPEN (no key needed).
# In production:  Render auto-generates a strong random key via generateValue.
API_SECRET_KEY=dev-secret-key

# Admin key — protects /api/admin/* endpoints (key management, usage analytics).
# In production: Render auto-generates via generateValue.
ADMIN_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DB_MODE=demo                     # demo (SQLite) | oracle
DB_PATH=./demo.db                # SQLite path (Render uses /data/demo.db)

# Oracle EBS (only needed if DB_MODE=oracle)
ORACLE_HOST=161.118.185.249
ORACLE_PORT=1521
ORACLE_SID=EBSDB
ORACLE_USER=apps
ORACLE_PASS=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # Get from https://console.anthropic.com

# ── Business rules (optional — sensible defaults already set) ─────────────────
DEDUP_NAME_THRESHOLD=0.88        # Jaro-Winkler similarity threshold
DEDUP_ADDRESS_THRESHOLD=0.90
CREDIT_INCREASE_PCT=0.15         # 15 % increase when payment is good
CREDIT_DECREASE_PCT=0.25         # 25 % decrease when payment is poor
AT_RISK_DAYS=60                  # No order for 60+ days → AT-RISK
DORMANT_DAYS=180                 # No order for 180+ days → DORMANT
ARCHIVE_DAYS=365                 # No order for 365+ days → eligible for archive
